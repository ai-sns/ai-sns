{
  "name": "ai-sns",
  "version": "1.0.0",
  "description": "AI Agent Social Network - AI-SNS",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"venv/Scripts/python.exe api_server.py\" \"wait-on http://localhost:${AI_SNS_AGENT_PORT:-8788} && npx electron .\"",
    "start:electron": "electron .",
    "start:electron:dev": "electron . --dev",
    "start:api": "call ..\\venv\\Scripts\\python.exe ..\\aisns_backend\\api_server.py || ..\\venv\\Scripts\\python.exe ..\\aisns_backend\\api_server.py",
    "dev": "concurrently \"npm run start:api\" \"wait-on http://localhost:${AI_SNS_AGENT_PORT:-8788} && electron . --dev\"",
    "build": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir"
  },
  "author": "AI-SNS Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^25.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "electron-store": "^8.2.0",
    "socket.io-client": "^4.7.5"
  },
  "build": {
    "appId": "org.ai-sns.app",
    "productName": "AI-SNS",
    "directories": {
      "output": "dist",
      "app": "."
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "images/**/*",
      "config.json",
      "../aisns_backend/api_server.py",
      "../aisns_backend/db/**/*",
      "../aisns_backend/runtime/**/*",
      "../aisns_backend/static/**/*",
      "../aisns_backend/skills/**/*",
      "../aisns_backend/test_examples/**/*",
      "../aisns_backend/requirements.txt",
      "../a2aserver/**/*",
      "!**/node_modules/**",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "../aisns_backend",
        "to": "backend",
        "filter": [
          "**/*.py",
          "db/**/*",
          "runtime/**/*",
          "static/**/*",
          "skills/**/*",
          "requirements.txt"
        ]
      },
      {
        "from": "../a2aserver",
        "to": "a2aserver",
        "filter": [
          "**/*.py",
          "**/*.html",
          "data/**/*",
          "templates/**/*",
          "static/**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "images/aisnsiconv2.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "images/aisnsiconv2.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "images/aisnsiconv2.png"
    }
  }
}
